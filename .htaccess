Options -MultiViews
RewriteEngine On

# Redirige les .html vers l'URL propre (301 permanent)
RewriteCond %{THE_REQUEST} \s/+([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Sert le bon fichier .html quand l'URL propre est demandée
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/?$ $1.html [L]

# Idem pour les sous-dossiers (ex: faq/importance-du-montage-video)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^/]+)/([^/]+)/?$ $1/$2.html [L]
